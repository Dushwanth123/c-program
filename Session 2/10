#include <iostream>
using namespace std;

int main()
{
    int a = 10, b = 5, c = 2;

    // Expression without parentheses
    int result1 = a + b * c;

    // Expression with parentheses
    int result2 = (a + b) * c;

    // Display results
    cout << "Values: a = " << a << ", b = " << b << ", c = " << c << endl;

    cout << "Expression: a + b * c = " << result1 << endl;
    cout << "Expression: (a + b) * c = " << result2 << endl;

    return 0;
}
