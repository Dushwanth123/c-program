#include <iostream>
using namespace std;

int main()
{
    int a, b;

    // Read values
    cout << "Enter two integers: ";
    cin >> a >> b;

    cout << "Initial value of a = " << a << endl;

    // Assignment operator
    a = b;
    cout << "After a = b, a = " << a << endl;

    // Reset value of a
    cout << "Enter a new value for a: ";
    cin >> a;

    // Compound assignment operators
    a += b;
    cout << "After a += b, a = " << a << endl;

    a -= b;
    cout << "After a -= b, a = " << a << endl;

    a *= b;
    cout << "After a *= b, a = " << a << endl;

    if (b != 0)
    {
        a /= b;
        cout << "After a /= b, a = " << a << endl;

        a %= b;
        cout << "After a %= b, a = " << a << endl;
    }
    else
    {
        cout << "Division and modulus operations cannot be performed because b = 0." << endl;
    }

    return 0;
}
