#include <iostream>
using namespace std;

int main()
{
    bool a = true;
    bool b = false;

    // Logical operators
    cout << "Value of a = " << a << endl;
    cout << "Value of b = " << b << endl;

    cout << "a && b = " << (a && b) << endl;
    cout << "a || b = " << (a || b) << endl;
    cout << "!a = " << (!a) << endl;
    cout << "!b = " << (!b) << endl;

    return 0;
}
