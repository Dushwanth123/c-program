#include <iostream>
using namespace std;

int main()
{
    int a = 10;
    float b = 3.5;

    // Implicit type conversion
    float sum = a + b;

    // Explicit type casting
    float result = (float)a / 3;

    // Display results
    cout << "Value of a = " << a << endl;
    cout << "Value of b = " << b << endl;

    cout << "Implicit Type Conversion (a + b) = " << sum << endl;
    cout << "Explicit Type Casting ((float)a / 3) = " << result << endl;

    return 0;
}
