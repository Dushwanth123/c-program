#include <iostream>
using namespace std;

int main() {
    int N, sum = 0;

    // Read the value of N
    cout << "Enter the value of N: ";
    cin >> N;

    // Calculate the sum of natural numbers from 1 to N
    for (int i = 1; i <= N; i++) {
        sum += i;
    }

    // Display the result
    cout << "Sum of natural numbers from 1 to " << N << " = " << sum << endl;

    return 0;
}
