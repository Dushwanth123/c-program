#include <iostream>
using namespace std;

int main() {
    int num, i;
    bool isPrime = true;

    // Read a number
    cout << "Enter a positive integer: ";
    cin >> num;

    // Check if the number is prime
    if (num <= 1) {
        isPrime = false;
    } else {
        for (i = 2; i <= num / 2; i++) {
            if (num % i == 0) {
                isPrime = false;
                break;
            }
        }
    }

    // Display the result
    if (isPrime)
        cout << num << " is a Prime number." << endl;
    else
        cout << num << " is not a Prime number." << endl;

    return 0;
}
