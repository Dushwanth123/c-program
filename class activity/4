#include <iostream>
using namespace std;

int main() {
    int num;

    // Read a number
    cout << "Enter a number: ";
    cin >> num;

    // Check whether the number is odd or even
    if (num % 2 == 0)
        cout << num << " is an Even number." << endl;
    else
        cout << num << " is an Odd number." << endl;

    return 0;
}
